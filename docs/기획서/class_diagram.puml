@startuml
title ProjectFR Runtime Architecture (post-pivot snapshot)
skinparam classAttributeIconSize 0
skinparam packageStyle rectangle

' ─────────────────────────────────────────
' CORE
' ─────────────────────────────────────────
package "Core" {
  class GameManager <<Autoload Singleton>> {
    + Instance : GameManager
    - CurrentBattle : BattleManager?
    - Clipboard : ClipboardSystem
    - StatusEffects : StatusEffectSystem
    + StartNewBattle()
    + EndCurrentBattle()
  }
}

' ─────────────────────────────────────────
' BATTLE LAYER (legacy — kept in parallel)
' ─────────────────────────────────────────
package "Battle (legacy)" #EEEEEE {
  class BattleManager <<legacy>> {
    - Player : ActorState
    - Enemies : List<ActorState>
    - CurrentState : BattleState
    - TurnCount : int
    + StartBattle()
    + ExecutePlayerAction(IAction, ActionContext)
    + ProcessEnemyTurns()
    + AddLog(string)
  }

  class ActorState {
    + Id : string
    + CurrentHp / MaxHp : int
    + CurrentAp / MaxAp : int
    + TakeDamage(int)
    + ConsumeAp(int)
  }

  BattleManager "1" *-- "*" ActorState
}

' ─────────────────────────────────────────
' INFILTRATION LAYER (active runtime)
' ─────────────────────────────────────────
package "Infiltration" {
  class InfiltrationManager {
    + State : InfiltrationState
    + SecurityAgents : List<SecurityAgent>
    + Mission : MissionData
    + Initialize(startPath, knownNodes)
    + ProcessPlayerTurn()
    + ProcessSecurityTurns()
    + EnqueueCommand(CommandQueueEntry)
  }

  class InfiltrationState {
    + CurrentFolderPath : string
    + TurnCount / Trace / MaxTrace : int
    + AlertStage : SecurityAwarenessStage
    + RunStatus : RunStatus
    + CursorAgent : CursorAgent
    + Windows : List<ExplorerWindowState>
    + Clipboard : List<ClipboardEntry>
    + PouchCache : List<ClipboardEntry>
    + ActiveOperations : List<FileOperation>
    + CommandQueue : List<CommandQueueEntry>
    + EventLog : List<string>
    + TrackedPathTurns / ForcedLockTurns / ScanPressureTurns : Dict<string,int>
    + AddLog(string)
  }

  class CursorAgent {
    + CurrentNodePath : string
    + ActionPoints : int
    + ClipboardCapacity : int
    + PouchCapacity : int
    + PouchMaxFileSize : long
    + IsDetected : bool
  }

  class SecurityAgent {
    + AgentType : SecurityAgentType
    + PatrolRoute : List<string>
    + SightRange : int
    + AwarenessState : SecurityAwarenessStage
    + BehaviorKey : string
  }

  class FileOperation {
    + OperationType : OperationType
    + TargetPath : string
    + Progress : int
    + Status : OperationStatus
  }

  class CommandQueueEntry {
    + CommandType : string
    + TargetPath : string
    + ActionId : string
  }

  class ExplorerWindowState {
    + WindowType : ExplorerWindowType
    + Title : string
    + BoundPath : string
    + IsOpen / IsFocused : bool
    + SlotIndex : int
    + TraceModifier : int
  }

  InfiltrationManager "1" *-- "1" InfiltrationState
  InfiltrationManager "1" o-- "*" SecurityAgent
  InfiltrationState "1" *-- "1" CursorAgent
  InfiltrationState "1" o-- "*" FileOperation
  InfiltrationState "1" o-- "*" CommandQueueEntry
  InfiltrationState "1" o-- "*" ExplorerWindowState
}

' ─────────────────────────────────────────
' SECURITY BEHAVIOR PIPELINE
' ─────────────────────────────────────────
package "Security Behavior" {
  class SecurityBehaviorExecutor {
    + Execute(SecurityBehaviorContext)
  }
  class SecurityBehaviorContext {
    + Agent : SecurityAgent
    + State : InfiltrationState
    + Mission : MissionData
  }
  class SecurityBehaviorFactory <<static>> {
    + Build(behaviorKey) : ISecurityBehavior
  }

  SecurityBehaviorExecutor ..> SecurityBehaviorContext : uses
  SecurityBehaviorExecutor ..> SecurityBehaviorFactory : uses
  InfiltrationManager ..> SecurityBehaviorExecutor : drives
}

' ─────────────────────────────────────────
' ACTION SYSTEM
' ─────────────────────────────────────────
package "Action" {
  interface IAction {
    + ActionId : string
    + DisplayName : string
    + ApCost : int
    + Scope : TargetType
    + CanExecute(ActionContext) : bool
    + Execute(ActionContext) : ActionResult
  }

  abstract class ActionBase {
    + Conditions : List<IActionCondition>
    + CanExecute(ActionContext) : bool
  }

  interface IActionCondition {
    + ConditionId : string
    + Check(ActionContext) : bool
  }

  note bottom of IActionCondition
    Action.Conditions: MinAp, TargetAlive,
    ClipboardNotEmpty, NotStatus
  end note

  class ActionRegistry {
    + Register(IAction)
    + GetExecutableActions(ActionContext) : List<IAction>
  }

  class ActionContext {
    + Actor : ActorState
    + Target : ActorState?
    + TargetNode : NodeData?
    + Clipboard : ClipboardSystem?
    + StatusEffects : StatusEffectSystem?
  }

  class ActionResult {
    + Success : bool
    + Message : string
  }

  note bottom of IAction
    Action.Implementations (13): Open, Copy, Cut,
    Paste, Delete, Inspect, Compress,
    Search, LogForge, ShowHidden,
    Quarantine, PermissionOverride, Clean
  end note

  IAction <|.. ActionBase
  ActionBase <|-- OpenAction
  ActionBase <|-- DeleteAction
  ActionBase <|-- PasteAction
  ActionBase "1" o-- "*" IActionCondition
  ActionRegistry "1" o-- "*" IAction
  IAction ..> ActionContext : receives
  IAction ..> ActionResult : returns
}

' ─────────────────────────────────────────
' SKILLS (extensibility scaffold)
' ─────────────────────────────────────────
package "Skills" #EEFFEE {
  class SkillCatalog {
    + Register(SkillDefinition)
    + Get(skillId) : SkillDefinition?
  }
  class SkillExecutor {
    + Execute(SkillDefinition, context)
  }
  note bottom of SkillExecutor
    Composes actions into multi-step
    tactical skills via behavior nodes
  end note
}

' ─────────────────────────────────────────
' UI / SCENE
' ─────────────────────────────────────────
package "Scenes" {
  class BattleScene <<Node>> {
    - _battleManager : BattleManager
    - _infiltrationManager : InfiltrationManager
    + _Ready()
    + UpdateUI()
    + OnActionButtonPressed(string)
  }

  note right of BattleScene
    Drives both layers in parallel.
    Will phase out BattleManager calls
    as InfiltrationManager matures.
  end note

  class MainMenu <<Control>> {
    + _Ready()
    - RefreshMenu()
    - OnStartBattlePressed()
  }
}

' ─────────────────────────────────────────
' DATA · NODES & DATA · ACTIONS
' ─────────────────────────────────────────
package "Data" {
  package "Data · Nodes" {
    abstract class NodeData {
      + Name / Path : string
      + IsFolder : bool
      + Size : long
    }
    class FileNode
    class FolderNode {
      + Children : List<NodeData>
    }
    class SpecialFileNode

    NodeData <|-- FileNode
    NodeData <|-- FolderNode
    FileNode <|-- SpecialFileNode
  }

  package "Data · Actions" {
    class ContextActionData <<Resource>> {
      + ActionId : string
      + DisplayName : string
      + ApCost : int
      + Scope : TargetType
    }
  }
}

' ─────────────────────────────────────────
' MISSION
' ─────────────────────────────────────────
package "Mission" {
  class MissionData {
    + Id / Title / Briefing : string
    + Client : MissionClientProfile
    + ObjectiveType : MissionObjectiveType
    + TargetPath : string
    + TurnLimit : int
    + RewardCredits / RewardReputation : int
    + FailurePenaltyCredits / FailureHeat : int
  }

  class MissionClientProfile {
    + Name : string
    + Faction : string
    + Agenda / RiskNote : string
  }

  enum MissionObjectiveType {
    Extract
    Delete
    Scan
  }

  class MissionProgress {
    + ObjectiveCompleted : bool
    + RegisterAction(actionId, path) : string?
    + Resolve(...) : MissionResult
  }

  class MissionResult {
    + Success : bool
    + Summary : string
    + CreditsDelta / ReputationDelta / HeatDelta : int
    + TurnsUsed : int
  }

  class CampaignState <<static>> {
    + Credits / Reputation / Heat : int
    + MissionBoard : IReadOnlyList<MissionData>
    + CurrentMission : MissionData?
    + GetModifiers() : CampaignModifiers
    + ApplyMissionResult(MissionResult)
  }

  class CampaignModifiers {
    + HeatTurnPenalty : int
    + EnemyAttackBonus / ApBonus / HpBonus : int
    + Summary : string
  }

  MissionData "1" *-- "1" MissionClientProfile
  MissionData ..> MissionObjectiveType
  MissionProgress --> MissionData
  MissionProgress ..> MissionResult : returns
  CampaignState "1" o-- "*" MissionData
  CampaignState ..> CampaignModifiers : returns
}

' ─────────────────────────────────────────
' SYSTEMS (battle layer, shared)
' ─────────────────────────────────────────
package "Systems" {
  class ClipboardSystem {
    + Copy(NodeData)
    + Cut(NodeData)
    + Paste() : NodeData?
  }
  class StatusEffectSystem {
    + AddEffect(actorId, effect, duration)
    + HasEffect(actorId, effect) : bool
    + UpdateDurations()
  }
}

' ─────────────────────────────────────────
' TOP-LEVEL WIRING
' ─────────────────────────────────────────
GameManager "1" o-- "0..1" BattleManager
GameManager "1" o-- "1" ClipboardSystem
GameManager "1" o-- "1" StatusEffectSystem

BattleScene --> BattleManager : legacy path
BattleScene --> InfiltrationManager : active path
BattleScene --> ActionRegistry : resolves actions
BattleScene --> CampaignState : reads modifiers

BattleManager ..> ActionRegistry : uses
BattleManager ..> ClipboardSystem : uses
BattleManager ..> StatusEffectSystem : uses

InfiltrationManager ..> MissionData : runs
MainMenu --> CampaignState : browses board

@enduml
